# ─── Variables d'environnement — Edge Functions LASSI ────────────────────────
# Copie ce fichier en `.env` pour le développement local avec `supabase functions serve`.
# En production : Settings → Edge Functions → Secrets dans le dashboard Supabase.
# ATTENTION : ne jamais committer le fichier .env avec de vraies valeurs.

# ── Supabase (auto-injectés en production, requis en local) ──────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (envoi d'emails — signalements) ────────────────────────────────────
# Créer un compte gratuit sur https://resend.com puis : API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Wave Checkout ─────────────────────────────────────────────────────────────
# Obtenir sur : https://dashboard.wave.com → Developers → API Keys
# TODO: remplir dès réception des accès Wave Business
WAVE_API_KEY=
WAVE_SECRET_KEY=
WAVE_MERCHANT_ID=
WAVE_WEBHOOK_SECRET=   # Secret HMAC pour vérifier les callbacks Wave entrants

# ── Orange Money WebPay Sénégal ───────────────────────────────────────────────
# Obtenir sur : https://developer.orange.com → My Apps → Orange Money WebPay SN
# TODO: remplir dès réception des accès Orange Money Marchand
OM_API_KEY=
OM_MERCHANT_ID=
OM_WEBHOOK_SECRET=     # Secret HMAC pour vérifier les callbacks OM entrants

# ── Callbacks deep-link (utilisés dans les URLs de retour paiement) ───────────
# Format React Native : schéma défini dans app.json (scheme: "lassi")
# Exemple : lassi://visibility-success
APP_BASE_URL=lassi://

# ── Section 9 : CORS strict ────────────────────────────────────────────────────
# Origines autorisées à appeler les Edge Functions depuis un navigateur
# (dashboard admin lassi-admin), séparées par des virgules.
# Sans cette variable : seules les origines de développement local
# (localhost/127.0.0.1) sont autorisées — voir _shared/cors.ts.
# L'app mobile et les webhooks Wave/OM n'envoient pas d'en-tête Origin et ne
# sont pas concernés par CORS.
# TODO: remplir avec le(s) domaine(s) de production de lassi-admin une fois
# l'hébergement choisi.
ALLOWED_ORIGINS=https://admin.lassi.app
