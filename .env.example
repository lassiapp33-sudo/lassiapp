# Copie ce fichier en .env et remplis tes vraies valeurs
# Ne commit JAMAIS le fichier .env (il est dans .gitignore)

# === SUPABASE ===
EXPO_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ta_cle_anon_publique_ici

# === PAIEMENT LASSI ===
# 'simulation' = paiements auto-validés sans API externe (défaut dev)
# 'production' = branchement Wave/OM réel (nécessite les clés ci-dessous)
EXPO_PUBLIC_PAYMENT_MODE=simulation

# === WAVE (à remplir par l'ingénieur Wave) ===
WAVE_API_KEY=
WAVE_MERCHANT_ID=
WAVE_WEBHOOK_SECRET=

# === ORANGE MONEY (à remplir par l'ingénieur OM) ===
OM_API_KEY=
OM_MERCHANT_CODE=
OM_WEBHOOK_SECRET=
